@page "/brownian-motion"
@using System.Timers
@using MudBlazor.Charts
@using Pricer.Numerics
@implements IDisposable

<PageTitle>Brownian Motion</PageTitle>

<MudText Typo="Typo.h4" Class="mb-2">Brownian Motion Simulator</MudText>
<MudText Typo="Typo.body2" Class="mb-6">
    Visualise how the scaled symmetric random walk W⁽ⁿ⁾(t) = (1/√n)·M_nt converges to a Brownian motion,
    and how diffusive scaling Var(ΔX) = σ²(Δt)^α determines the nature of the limiting process.
</MudText>

<MudGrid>

    <!-- ══════════════════════════════════════════════════════════════════
         LECTURE 3 — Convergence & Diffusive Scaling
         ══════════════════════════════════════════════════════════════════ -->

    <!-- ── Slider 1: convergence ── -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1">
                Slider 1 — Scaled random walk W⁽ⁿ⁾
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-1">
                Each step is ±1/√n (coin toss), so Var[W⁽ⁿ⁾(t)−W⁽ⁿ⁾(s)] = t−s for all n.
                As n → ∞, the scaled random walk W⁽ⁿ⁾(t) converges to a Brownian motion W(t).
            </MudText>
            <MudSlider T="int"
                       Value="_n"
                       ValueChanged="OnNChanged"
                       Min="1" Max="500" Step="1"
                       Color="Color.Primary">
                n = @_n &nbsp;|&nbsp; step size = 1/√n ≈ @($"{1.0 / Math.Sqrt(_n):F4}") &nbsp;|&nbsp; Δt = @($"{1.0 / _n:F4}")
            </MudSlider>
            <MudText Typo="Typo.caption">@GetRandomWalkLabel()</MudText>
        </MudPaper>
    </MudItem>

    <!-- ── Slider 2: diffusive scaling ── -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1">
                Slider 2 — Variance exponent α &nbsp; [Var(ΔX) = σ²(Δt)^α]
            </MudText>
            <MudText Typo="Typo.body2" Class="mb-1">
                α &gt; 1 → Frozen &nbsp;|&nbsp; α = 1 → Brownian motion &nbsp;|&nbsp; α &lt; 1 → Explosion
            </MudText>
            <MudSlider T="double"
                       Value="_alpha"
                       ValueChanged="OnAlphaChanged"
                       Min="0.0" Max="2.0" Step="0.05"
                       Color="Color.Secondary">
                α = @($"{_alpha:F2}") &nbsp;|&nbsp; Var(X_t) = σ²t·(Δt)^(α−1) &nbsp;→&nbsp; @GetAlphaRegimeShort()
            </MudSlider>
            <MudText Typo="Typo.caption">
                Diffusive scaling requires α = 1, which forces ΔXk = √Δt · Yk with Yk i.i.d. N(0,1).
            </MudText>
        </MudPaper>
    </MudItem>

    <!-- ── Controls (Lecture 3) ── -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="1">
            <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3" Wrap="Wrap.Wrap">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           OnClick="Regenerate"
                           StartIcon="@Icons.Material.Filled.Refresh">
                    New Path
                </MudButton>
                <MudButton Variant="Variant.Outlined"
                           Color="Color.Secondary"
                           OnClick="ToggleAnimation"
                           StartIcon="@(_animating ? Icons.Material.Filled.Stop : Icons.Material.Filled.PlayArrow)">
                    @(_animating ? "Stop" : "Animate n → ∞")
                </MudButton>
                <MudText Typo="Typo.body2">Paths:</MudText>
                <MudSlider T="int"
                           Value="_numPaths"
                           ValueChanged="OnNumPathsChanged"
                           Min="1" Max="5" Step="1"
                           Style="width:120px"
                           Color="Color.Tertiary">
                    @_numPaths
                </MudSlider>
            </MudStack>
        </MudPaper>
    </MudItem>

    <!-- ── Chart (Lecture 3) ── -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudChart ChartType="ChartType.Timeseries"
                      ChartSeries="@_series"
                      ChartOptions="@_chartOptions"
                      Width="100%"
                      Height="420px" />
        </MudPaper>
    </MudItem>

    <!-- ── Theory boxes (Lecture 3) ── -->
    <MudItem xs="12" md="6">
        <MudAlert Severity="@GetNAlertSeverity()" Variant="Variant.Outlined">
            <MudText Typo="Typo.subtitle2">@GetNRegimeTitle()</MudText>
            <MudText Typo="Typo.body2">@GetNRegimeDescription()</MudText>
        </MudAlert>
    </MudItem>
    <MudItem xs="12" md="6">
        <MudAlert Severity="@GetAlphaAlertSeverity()" Variant="Variant.Outlined">
            <MudText Typo="Typo.subtitle2">@GetAlphaRegimeTitle()</MudText>
            <MudText Typo="Typo.body2">@GetAlphaRegimeDescription()</MudText>
        </MudAlert>
    </MudItem>

    <!-- ══════════════════════════════════════════════════════════════════
         LECTURE 4 — Correlated Brownian Motions
         ══════════════════════════════════════════════════════════════════ -->

    <MudItem xs="12">
        <MudDivider Class="my-4" />
        <MudText Typo="Typo.h5" Class="mb-1">Correlated Brownian Motions</MudText>
        <MudText Typo="Typo.body2" Class="mb-2">
            Two Brownian motions W₁ and W₂ via Cholesky decomposition:
            W₁ = Z₁ and W₂ = ρ·Z₁ + √(1−ρ²)·Z₂, where Z₁, Z₂ are independent.
        </MudText>
    </MudItem>

    <!-- ── Correlation slider ── -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1">Correlation ρ</MudText>
            <MudText Typo="Typo.body2" Class="mb-1">
                ρ = 1 → identical paths &nbsp;|&nbsp; ρ = 0 → independent &nbsp;|&nbsp; ρ = −1 → mirror image
            </MudText>
            <MudSlider T="double"
                       Value="_correlation"
                       ValueChanged="OnCorrelationChanged"
                       Min="-1.0" Max="1.0" Step="0.05"
                       Color="Color.Info">
                ρ = @($"{_correlation:F2}") &nbsp;|&nbsp; @GetCorrelationLabel()
            </MudSlider>
            <MudText Typo="Typo.caption">
                Cov(W₁(t), W₂(t)) = ρ·t &nbsp;·&nbsp; E[W₁(t)·W₂(t)] = ρ·t
            </MudText>
        </MudPaper>
    </MudItem>

    <!-- ── Steps slider (Lecture 4) ── -->
    <MudItem xs="12" md="6">
        <MudPaper Class="pa-4" Elevation="2">
            <MudText Typo="Typo.h6" Class="mb-1">Steps</MudText>
            <MudSlider T="int"
                       Value="_corrSteps"
                       ValueChanged="OnCorrStepsChanged"
                       Min="10" Max="500" Step="10"
                       Color="Color.Primary">
                n = @_corrSteps &nbsp;|&nbsp; Δt = @($"{1.0 / _corrSteps:F4}")
            </MudSlider>
            <MudButton Variant="Variant.Filled"
                       Color="Color.Info"
                       OnClick="RegenerateCorrelated"
                       StartIcon="@Icons.Material.Filled.Refresh"
                       Class="mt-3">
                New Paths
            </MudButton>
        </MudPaper>
    </MudItem>

    <!-- ── Chart (Lecture 4) ── -->
    <MudItem xs="12">
        <MudPaper Class="pa-4" Elevation="2">
            <MudChart ChartType="ChartType.Timeseries"
                      ChartSeries="@_corrSeries"
                      ChartOptions="@_corrChartOptions"
                      Width="100%"
                      Height="380px" />
        </MudPaper>
    </MudItem>

    <!-- ── Theory box (Lecture 4) ── -->
    <MudItem xs="12">
        <MudAlert Severity="@GetCorrelationAlertSeverity()" Variant="Variant.Outlined">
            <MudText Typo="Typo.subtitle2">@GetCorrelationRegimeTitle()</MudText>
            <MudText Typo="Typo.body2">@GetCorrelationRegimeDescription()</MudText>
        </MudAlert>
    </MudItem>

</MudGrid>

@code {

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 3 — State
    // ══════════════════════════════════════════════════════════════════

    private int    _n        = 50;
    private double _alpha    = 1.0;
    private int    _numPaths = 1;

    private List<ChartSeries<double>> _series = new();

    private bool _animating = false;
    private System.Timers.Timer? _timer;
    private int _animDir = 1;

    private static readonly DateTime _t0 = new DateTime(2024, 1, 1);

    private TimeSeriesChartOptions _chartOptions = new()
    {
        ShowLegend            = true,
        ShowDataMarkers       = false,
        YAxisRequireZeroPoint = false,
        LineStrokeWidth       = 1,
    };
    private TimeSeriesChartOptions _corrChartOptions = new()
    {
        ShowLegend            = true,
        ShowDataMarkers       = false,
        YAxisRequireZeroPoint = false,
        LineStrokeWidth       = 1,
    };

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 4 — State
    // ══════════════════════════════════════════════════════════════════

    private double _correlation = 0.5;
    private int    _corrSteps   = 200;

    private List<ChartSeries<double>> _corrSeries = new();

    // Shared RNG
    private readonly Random _rng = new();

    // ══════════════════════════════════════════════════════════════════
    // Lifecycle
    // ══════════════════════════════════════════════════════════════════

    protected override void OnInitialized()
    {
        RebuildChart();
        RebuildCorrelatedChart();
    }

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 3 — Callbacks & chart construction
    // ══════════════════════════════════════════════════════════════════

    private void OnNChanged(int value)        { _n        = value; RebuildChart(); }
    private void OnAlphaChanged(double value) { _alpha    = value; RebuildChart(); }
    private void OnNumPathsChanged(int value) { _numPaths = value; RebuildChart(); }
    private void Regenerate()                 => RebuildChart();

    private void RebuildChart()
    {
        _series = Enumerable.Range(0, _numPaths)
            .Select(p => new ChartSeries<double>
            {
                Name    = _numPaths == 1 ? "W⁽ⁿ⁾(t)" : $"W{p + 1}(t)",
                Data    = GeneratePath(),
                Visible = true,
            })
            .ToList();
    }

    /// <summary>
    /// One realisation of the scaled random walk with diffusive-scaling exponent α.
    ///   α = 1  → coin-toss ±1/√n  (exact CLT scaling)
    ///   α ≠ 1  → Gaussian increments (Δt)^(α/2) · N(0,1)
    /// </summary>
    private TimeValue<double>[] GeneratePath()
    {
        int    n  = _n;
        double dt = 1.0 / n;

        var    path = new TimeValue<double>[n + 1];
        double x    = 0.0;
        path[0] = new TimeValue<double>(_t0, x);

        for (int k = 1; k <= n; k++)
        {
            double dx;
            if (Math.Abs(_alpha - 1.0) < 1e-9)
            {
                double coin = _rng.NextDouble() < 0.5 ? -1.0 : 1.0;
                dx = coin / Math.Sqrt(n);
            }
            else
            {
                dx = Math.Pow(dt, _alpha / 2.0) * SampleNormal();
            }

            x      += dx;
            path[k] = new TimeValue<double>(_t0.AddSeconds(k * dt * 1000.0), x);
        }

        return path;
    }

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 3 — Animation
    // ══════════════════════════════════════════════════════════════════

    private void ToggleAnimation()
    {
        if (_animating)
        {
            _timer?.Stop();
            _animating = false;
        }
        else
        {
            _animating = true;
            _n         = 1;
            _animDir   = 1;
            _timer          = new System.Timers.Timer(60);
            _timer.Elapsed  += OnTimerTick;
            _timer.AutoReset = true;
            _timer.Start();
        }
    }

    private void OnTimerTick(object? sender, ElapsedEventArgs e)
    {
        _n += _animDir * 2;
        if (_n >= 500) { _n = 500; _animDir = -1; }
        if (_n <= 1)   { _n = 1;   _animDir =  1; }
        RebuildChart();
        InvokeAsync(StateHasChanged);
    }

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 4 — Callbacks & chart construction
    // ══════════════════════════════════════════════════════════════════

    private void OnCorrelationChanged(double value) { _correlation = value; RebuildCorrelatedChart(); }
    private void OnCorrStepsChanged(int value)      { _corrSteps   = value; RebuildCorrelatedChart(); }
    private void RegenerateCorrelated()             => RebuildCorrelatedChart();

    private void RebuildCorrelatedChart()
    {
        var (w1, w2) = CorrelatedBrownianGenerator.Generate(
            steps:       _corrSteps,
            correlation: _correlation,
            alpha:       1.0,
            rng:         _rng);

        double dt = 1.0 / _corrSteps;

        var data1 = Enumerable.Range(0, _corrSteps + 1)
            .Select(i => new TimeValue<double>(_t0.AddSeconds(i * dt * 1000.0), w1[i] * 10))
            .ToArray();

        var data2 = Enumerable.Range(0, _corrSteps + 1)
            .Select(i => new TimeValue<double>(_t0.AddSeconds(i * dt * 1000.0), w2[i] * 10))
            .ToArray();

        _corrSeries = new List<ChartSeries<double>>
        {
            new() { Name = "W₁(t)", Data = data1, Visible = true },
            new() { Name = "W₂(t)", Data = data2, Visible = true },
        };
    }

    // ══════════════════════════════════════════════════════════════════
    // Shared utility
    // ══════════════════════════════════════════════════════════════════

    private double SampleNormal()
    {
        double u1 = 1.0 - _rng.NextDouble();
        double u2 = 1.0 - _rng.NextDouble();
        return Math.Sqrt(-2.0 * Math.Log(u1)) * Math.Cos(2.0 * Math.PI * u2);
    }

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 3 — Labels (n)
    // ══════════════════════════════════════════════════════════════════

    private string GetRandomWalkLabel() => _n switch
    {
        <= 5   => "⚠️  n very small — large ±1/√n jumps, clearly discrete",
        <= 20  => "🔄  Coarse scaled RW — jagged, piecewise linear path",
        <= 100 => "📈  Intermediate — path smoothing towards BM",
        _      => "✅  Large n — W⁽ⁿ⁾ closely approximates Brownian motion"
    };

    private string GetNRegimeTitle() => _n switch
    {
        <= 5   => "Discrete random walk (n very small)",
        <= 20  => "Coarse scaled random walk",
        <= 100 => "Intermediate approximation",
        _      => "Near-Brownian motion (n large)"
    };

    private string GetNRegimeDescription() => _n switch
    {
        <= 5   =>
            "W⁽ⁿ⁾(t) = (1/√n)·M_nt with only a few steps. Steps of size ±1/√n are clearly visible. " +
            "Var[W⁽ⁿ⁾(t)] = t, but the path is far from continuous.",
        <= 20  =>
            "The path is piecewise linear with identifiable ±1/√n jumps. " +
            "Quadratic variation [W⁽ⁿ⁾,W⁽ⁿ⁾](t) = t already holds for every n.",
        <= 100 =>
            "Increments are shrinking. The path is converging towards a continuous limit. " +
            "The finite-dimensional distributions already closely resemble N(0,t−s).",
        _      =>
            "n is large: the scaled random walk has converged to W, a standard Brownian motion " +
            "with Var[W(t)] = t and nowhere-differentiable, continuous paths."
    };

    private Severity GetNAlertSeverity() => _n switch
    {
        <= 5   => Severity.Warning,
        <= 20  => Severity.Info,
        <= 100 => Severity.Normal,
        _      => Severity.Success
    };

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 3 — Labels (α)
    // ══════════════════════════════════════════════════════════════════

    private string GetAlphaRegimeShort() => _alpha switch
    {
        > 1.05  => "❄️ Frozen",
        >= 0.95 => "🌊 BM",
        _       => "💥 Explosion"
    };

    private string GetAlphaRegimeTitle() => _alpha switch
    {
        > 1.05  => $"Freezing (α = {_alpha:F2} > 1)",
        >= 0.95 => "Diffusive / Brownian motion (α ≈ 1)",
        _       => $"Explosion (α = {_alpha:F2} < 1)"
    };

    private string GetAlphaRegimeDescription() => _alpha switch
    {
        > 1.05  =>
            $"Var(ΔX) = σ²(Δt)^{_alpha:F2} shrinks too fast. " +
            $"Var(X_t) = σ²t·(Δt)^({_alpha:F2}−1) → 0 as Δt→0. " +
            "The process freezes at its mean — randomness disappears.",
        >= 0.95 =>
            "α = 1: unique CLT-compatible scaling. " +
            "ΔXk = √Δt · Yk forces Var(X_t) → σ²t — a finite, nonzero limit. " +
            "The limit process is a standard Brownian motion.",
        _       =>
            $"Var(ΔX) = σ²(Δt)^{_alpha:F2} shrinks too slowly. " +
            $"Var(X_t) = σ²t·(Δt)^({_alpha:F2}−1) → ∞ as Δt→0. " +
            "No finite continuous-time limit exists — the process explodes."
    };

    private Severity GetAlphaAlertSeverity() => _alpha switch
    {
        > 1.05  => Severity.Info,
        >= 0.95 => Severity.Success,
        _       => Severity.Error
    };

    // ══════════════════════════════════════════════════════════════════
    // LECTURE 4 — Labels (ρ)
    // ══════════════════════════════════════════════════════════════════

    private string GetCorrelationLabel() => _correlation switch
    {
        >= 0.95  => "nearly identical paths",
        >= 0.5   => "strongly positive correlation",
        >= 0.1   => "weakly positive correlation",
        > -0.1   => "approximately independent",
        > -0.5   => "weakly negative correlation",
        > -0.95  => "strongly negative correlation",
        _        => "nearly mirror-image paths"
    };

    private string GetCorrelationRegimeTitle() => _correlation switch
    {
        >= 0.95  => "Perfect positive correlation (ρ ≈ 1)",
        >= 0.1   => $"Positive correlation (ρ = {_correlation:F2})",
        > -0.1   => "Independent Brownian motions (ρ ≈ 0)",
        > -0.95  => $"Negative correlation (ρ = {_correlation:F2})",
        _        => "Perfect negative correlation (ρ ≈ −1)"
    };

    private string GetCorrelationRegimeDescription() => _correlation switch
    {
        >= 0.95  =>
            "W₁ and W₂ are essentially the same path. " +
            "Cov(W₁(t), W₂(t)) = ρ·t ≈ t. Used in models where two assets share the same shock.",
        >= 0.1   =>
            $"W₁ and W₂ tend to move in the same direction. " +
            $"Cov(W₁(t), W₂(t)) = {_correlation:F2}·t. " +
            "Typical in equity models where stocks in the same sector co-move.",
        > -0.1   =>
            "W₁ and W₂ are (nearly) independent. Cov ≈ 0. " +
            "The two paths are generated from orthogonal noise sources Z₁ and Z₂.",
        > -0.95  =>
            $"W₁ and W₂ tend to move in opposite directions. " +
            $"Cov(W₁(t), W₂(t)) = {_correlation:F2}·t. " +
            "Used in hedging models, e.g. a stock and its put option.",
        _        =>
            "W₁ and W₂ are mirror images: W₂ = −W₁. " +
            "Cov = −t. Perfect negative correlation eliminates diversification benefit."
    };

    private Severity GetCorrelationAlertSeverity() => _correlation switch
    {
        >= 0.5  => Severity.Warning,
        > -0.5  => Severity.Success,
        _       => Severity.Info
    };

    // ══════════════════════════════════════════════════════════════════
    // IDisposable
    // ══════════════════════════════════════════════════════════════════

    public void Dispose()
    {
        _timer?.Stop();
        _timer?.Dispose();
    }
}
